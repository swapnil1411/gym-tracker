rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Every user can read and write only their own document tree.
    // users/{uid} plus everything nested beneath it:
    //   profile, settings, plan/{dayOfWeek}, completions/{YYYY-MM-DD}
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Anything not matched above is denied by default.
  }
}
